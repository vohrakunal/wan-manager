# Copy this to .env and fill in your values

# Server
PORT=8080
HOST=192.168.1.254
NODE_ENV=production

# Auth — CHANGE THESE!
ADMIN_USER=admin
ADMIN_PASS=changeme
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/wan-manager

# DHCP file paths (defaults match Ubuntu 24.04 isc-dhcp-server)
DHCP_LEASES_FILE=/var/lib/dhcp/dhcpd.leases
DHCPD_CONF_FILE=/etc/dhcp/dhcpd.conf
DHCP_POOL_START=100
DHCP_POOL_END=200

# Log paths
FAILOVER_LOG=/var/log/wan-failover.log
WAN_MGR_LOG=/var/log/wan-manager.log
